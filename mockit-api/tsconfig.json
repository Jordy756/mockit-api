{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "rootDir": "src",
    "outDir": "build",
    "declaration": false,
    "sourceMap": false,
    "noEmitOnError": false,
    "incremental": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
