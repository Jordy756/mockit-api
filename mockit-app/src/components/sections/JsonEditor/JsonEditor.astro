---
import GenerateIcon from "@components/icons/Generate.astro";
import Button from "@components/ui/Button.astro";

const initialJson = `{
  "name": "Nombre de una persona",
  "age": "Edad entre 10 y 20 años",
  "email": "Correo electrónico de prueba"
}`;
---

<section class="relative h-full flex flex-col gap-4 p-4">
  <header class="flex justify-between items-center flex-wrap gap-8">
    <h2 class="text-xl font-semibold">Base JSON</h2>
    <div class="flex items-center flex-wrap gap-4">
      <Button id="format-btn" variant="secondary" class="flex-1">Formatear</Button>
      <Button class="flex-1">
        Generar Datos
        <GenerateIcon width={20} class="text-neutral-950" />
      </Button>
    </div>
  </header>
  <div class="relative flex-1 bg-[#0d1117] border border-neutral-800 overflow-hidden">
    <textarea
      id="json-input"
      spellcheck="false"
      class="absolute inset-0 p-4 resize-none bg-transparent text-transparent caret-neutral-50 outline-none z-10"
      >{initialJson}</textarea
    >
    <pre
      id="json-display"
      aria-hidden="true"
      class="absolute inset-0 p-4 overflow-auto pointer-events-none whitespace-pre-wrap break-all z-0 text-neutral-50">
    </pre>
  </div>
</section>

<script>
  const jsonInput = document.getElementById("json-input") as HTMLTextAreaElement;
  const jsonDisplay = document.getElementById("json-display");
  const formatBtn = document.getElementById("format-btn");

  function syntaxHighlight(json: string) {
    const escaped = json.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    return escaped.replace(
      /("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g,
      function (match) {
        let cls = "text-[#0550ae] dark:text-[#79c0ff]"; // number
        if (/^"/.test(match)) {
          if (/:$/.test(match)) {
            // GitHub keys
            cls = "text-[#24292f] dark:text-[#7ee787] font-semibold";
          } else {
            // GitHub strings
            cls = "text-[#0a3069] dark:text-[#a5d6ff]";
          }
        } else if (/true|false|null/.test(match)) {
          // null/booleans
          cls = "text-[#cf222e] dark:text-[#ff7b72] scale-[1.02] inline-block";
        }
        return '<span class="' + cls + '">' + match + "</span>";
      },
    );
  }

  function update() {
    if (jsonInput && jsonDisplay) {
      let val = jsonInput.value;
      if (val[val.length - 1] === "\n") {
        val += " ";
      }
      jsonDisplay.innerHTML = syntaxHighlight(val);
    }
  }

  if (jsonInput) {
    jsonInput.addEventListener("input", update);
    jsonInput.addEventListener("scroll", () => {
      if (jsonDisplay) {
        jsonDisplay.scrollTop = jsonInput.scrollTop;
        jsonDisplay.scrollLeft = jsonInput.scrollLeft;
      }
    });
    // Renderizado inicial
    update();
  }

  if (formatBtn && jsonInput) {
    formatBtn.addEventListener("click", () => {
      try {
        const parsed = JSON.parse(jsonInput.value);
        jsonInput.value = JSON.stringify(parsed, null, 2);
        update();
      } catch (e) {
        alert("El JSON ingresado es inválido, por favor corrige los errores antes de formatear.");
      }
    });
  }
</script>
