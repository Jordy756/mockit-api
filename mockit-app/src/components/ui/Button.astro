---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"button"> {
  variant?: "primary" | "secondary";
}

const { variant = "primary", class: className, ...rest } = Astro.props;
---

<button
  class:list={[
    "flex items-center justify-center gap-3 py-2 px-4 border rounded-md font-medium cursor-pointer whitespace-nowrap transition-opacity hover:opacity-80",
    `btn-${variant}`,
    className,
  ]}
  {...rest}
>
  <slot />
</button>
